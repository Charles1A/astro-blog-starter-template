---
// src/pages/index.astro
// Fire Spark Analytics — Homepage
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Fire Spark Analytics — Customized Analytics for Busy E-preneurs</title>
  <meta name="description" content="Customized analytics for busy e-preneurs. Delegate the analytics to Charles Ashton and refocus on what you enjoy." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&display=swap" rel="stylesheet" />
  <style>
    /* ── Reset & Tokens ──────────────────────────────── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --orange:  #F97316;
      --gold:    #FAAC18;
      --charcoal:#1C1C1E;
      --ink:     #2D2D2D;
      --slate:   #5A5A6A;
      --cloud:   #F5F5F0;
      --white:   #FFFFFF;
      --nav-h:   72px;
      --max-w:   1100px;

      --font-display: 'Playfair Display', Georgia, serif;
      --font-body:    'DM Sans', system-ui, sans-serif;

      /* ── Hero tuning knobs ───────────────────────────
         Adjust these values to reposition hero elements
         without touching anything else.
      ───────────────────────────────────────────────── */

      /* Overall hero vertical padding (top / bottom) */
      --hero-pad-top:    1.75rem;
      --hero-pad-bottom: 1.5rem;

      /* Gap between headline and the two columns */
      --hero-headline-gap: 1.9rem;

      /* Gap between columns and CTA button */
      --hero-cta-gap: 1.25rem;

      /* Headline font size (clamp: min, preferred, max) */
      --hero-headline-size: clamp(1.6rem, 2.6vw, 2.4rem);

      /* Chart stack: total height of the stacked area */
      --chart-stack-h: 210px;

      /* Chart stack: vertical offset between each chart card */
      --chart-step: 50px;

      /* Chart card width as % of the right column */
      --chart-w: 80%;

      /* Donut: gap above it (below chart stack) */
      --donut-gap: 60px;

      /* Donut: width as % of right column */
      --donut-w: 50%;

      /* Donut: max pixel width */
      --donut-max-w: 275px;

      /* Gap between the two hero columns */
      --hero-col-gap: 3rem;

      /* ── Intro blurb card ────────────────────────────
         Controls the left card in the hero section.
      ───────────────────────────────────────────────── */

      /* Border thickness */
      --blurb-border-width: 2.5px;

      /* Border color */
      --blurb-border-color: var(--orange);

      /* Border radius */
      --blurb-border-radius: 6px;

      /* Internal padding (top/bottom and left/right) */
      --blurb-pad-y: 1.4rem;
      --blurb-pad-x: 2rem;

      /* Font size */
      --blurb-font-size: 1.15rem;

      /* Line height */
      --blurb-line-height: 1.85;

      /* Gap between the two paragraphs */
      --blurb-para-gap: 1.1rem;

      /* Gap above/below the • • • and ～ decorators */
      --blurb-decor-gap: 0.4rem;
    }

    html { scroll-behavior: smooth; }

    body {
      font-family: var(--font-body);
      color: var(--ink);
      background: var(--white);
      line-height: 1.6;
      font-weight: 300;
    }

    img { display: block; max-width: 100%; }
    a   { color: inherit; text-decoration: none; }

    /* ── Nav ─────────────────────────────────────────── */
    nav {
      position: sticky;
      top: 0;
      z-index: 100;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 5vw;
      height: var(--nav-h);
      background: var(--charcoal);
    }
    .nav-logo {
      font-family: var(--font-display);
      font-size: 1.6rem;
      letter-spacing: -0.02em;
    }
    .nav-logo span.fire  { color: var(--orange); }
    .nav-logo span.spark { color: var(--gold); }
    .nav-logo span.rest  { color: var(--white); }
    .nav-contact {
      font-size: 0.9rem;
      font-weight: 500;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--white);
      border: 1px solid rgba(255,255,255,0.35);
      padding: 0.45rem 1.25rem;
      border-radius: 2px;
      transition: background 0.2s, color 0.2s;
    }
    .nav-contact:hover { background: var(--orange); border-color: var(--orange); }

    /* ── Shared section shell ────────────────────────── */
    section { padding: 5rem 5vw; }

    .section-label {
      display: inline-block;
      font-size: 0.75rem;
      font-weight: 500;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--orange);
      margin-bottom: 0.75rem;
    }
    .section-title {
      font-family: var(--font-display);
      font-size: clamp(1.8rem, 3vw, 2.6rem);
      line-height: 1.2;
      color: var(--charcoal);
      margin-bottom: 1rem;
    }

    /* ── HERO ────────────────────────────────────────── */
    .hero {
      background: var(--white);
      padding: var(--hero-pad-top) 5vw var(--hero-pad-bottom);
      border-bottom: 1px solid #e8e8e0;
    }

    /* Centered headline above the two columns */
    .hero-headline-wrap {
      text-align: center;
      max-width: var(--max-w);
      margin: 0 auto var(--hero-headline-gap);
    }
    .hero-headline {
      font-family: var(--font-display);
      font-size: var(--hero-headline-size);
      line-height: 1.15;
      font-weight: 900;
      color: var(--charcoal);
    }
    .hero-headline em { font-style: normal; color: var(--orange); display: block; }

    /* Two-column body */
    .hero-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 2.5rem;
      align-items: start;
      max-width: var(--max-w);
      margin: 0 auto;
    }

    /* Left card */
    .hero-left {
      background: var(--white);
      border: var(--blurb-border-width) solid var(--blurb-border-color);
      border-radius: var(--blurb-border-radius);
      padding: var(--blurb-pad-y) var(--blurb-pad-x);
      font-size: var(--blurb-font-size);
      color: var(--slate);
      line-height: var(--blurb-line-height);
    }
    .hero-left p + p { margin-top: var(--blurb-para-gap); }
    .hero-decor {
      text-align: center;
      margin: var(--blurb-decor-gap) 0;
      opacity: 0.3;
      color: var(--slate);
      font-size: 1.1rem;
      letter-spacing: 0.3em;
      user-select: none;
    }
    .hero-decor-wave {
      font-size: 1.6rem;
      letter-spacing: 0;
    }

    /* Right column: chart stack then donut below, left-aligned */
    .hero-right {
      display: flex;
      flex-direction: column;
    }
    .chart-stack {
      position: relative;
      width: 100%;
      height: var(--chart-stack-h);
      flex-shrink: 0;
    }
    .chart-item {
      position: absolute;
      background: var(--white);
      border: 1px solid #e0dfd7;
      border-radius: 6px;
      overflow: hidden;
      box-shadow: 0 4px 18px rgba(0,0,0,0.13), 0 1px 4px rgba(0,0,0,0.07);
      width: var(--chart-w);
    }
    .chart-item img { width: 100%; height: auto; display: block; }
    /* Descending diagonal offsets — driven by --chart-step */
    .chart-item:nth-child(1) { top: 0;                          left: 0;   z-index: 3; }
    .chart-item:nth-child(2) { top: var(--chart-step);          left: 10%; z-index: 2; }
    .chart-item:nth-child(3) { top: calc(var(--chart-step)*2);  left: 20%; z-index: 1; }

    .hero-donut {
      margin-top: var(--donut-gap);
      display: flex;
      justify-content: flex-start;
    }
    .hero-donut img {
      width: var(--donut-w);
      max-width: var(--donut-max-w);
      height: auto;
    }

    /* Centered CTA below both columns */
    .hero-cta-wrap {
      text-align: center;
      max-width: var(--max-w);
      margin: var(--hero-cta-gap) auto 0;
    }
    .hero-cta {
      display: inline-block;
      background: var(--orange);
      color: var(--white);
      font-weight: 500;
      font-size: 1rem;
      padding: 0.85rem 2.5rem;
      border-radius: 2px;
      letter-spacing: 0.04em;
      transition: background 0.2s, transform 0.15s;
    }
    .hero-cta:hover { background: #e56500; transform: translateY(-1px); }

    /* ── WHY ─────────────────────────────────────────── */
    .why {
      background: var(--cloud);
      text-align: center;
    }
    .why-inner {
      max-width: 720px;
      margin: 0 auto;
    }
    .why-body {
      font-size: 1.2rem;
      color: var(--slate);
      line-height: 1.8;
      text-align: left;
    }
    .why-body p + p { margin-top: 1rem; }
    .why-highlight {
      margin-top: 2rem;
      background: var(--white);
      border-top: 3px solid var(--orange);
      border-radius: 6px;
      padding: 1.5rem 1.75rem;
      text-align: left;
    }
    .why-highlight p { font-size: 1.2rem; color: var(--ink); line-height: 1.7; }
    .why-highlight p + p { margin-top: 0.85rem; }
    .why-highlight strong { font-weight: 500; color: var(--charcoal); }

    /* ── SERVICES ────────────────────────────────────── */
    .services {
      background: var(--charcoal);
      color: var(--white);
      text-align: center;
    }
    .services .section-label { color: var(--gold); }
    .services .section-title { color: var(--white); }
    .services-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
      margin-top: 2.5rem;
      max-width: var(--max-w);
      margin-left: auto;
      margin-right: auto;
    }
    .service-card {
      background: rgba(255,255,255,0.06);
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: 6px;
      padding: 1.5rem 1.25rem;
      transition: background 0.2s;
      text-align: left;
    }
    .service-card:hover { background: rgba(249,115,22,0.15); }
    .service-card .icon { font-size: 1.75rem; margin-bottom: 0.75rem; }
    .service-card h4 { font-weight: 500; font-size: 1rem; margin-bottom: 0.4rem; color: var(--white); }
    .service-card p  { font-size: 0.875rem; color: rgba(255,255,255,0.6); }

    /* ── ABOUT ───────────────────────────────────────── */
    .about {
      background: var(--white);
    }
    .about-inner {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 5rem;
      align-items: start;
      max-width: var(--max-w);
      margin: 0 auto;
    }
    .about-bio { font-size: 1.05rem; color: var(--slate); line-height: 1.75; }
    .about-bio p + p { margin-top: 1rem; }
    .about-skills {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      margin-top: 1.25rem;
    }
    .skill-tag {
      background: var(--cloud);
      border: 1px solid #e0e0d8;
      color: var(--ink);
      font-size: 0.8rem;
      font-weight: 500;
      padding: 0.3rem 0.85rem;
      border-radius: 999px;
    }
    .about-name {
      font-family: var(--font-display);
      font-size: 1.2rem;
      color: var(--charcoal);
      margin-top: 1.5rem;
    }
    .about-name span { color: var(--slate); font-family: var(--font-body); font-size: 0.9rem; font-weight: 300; }

    /* ── CONTACT FORM ────────────────────────────────── */
    .contact-box {
      background: var(--cloud);
      border-radius: 8px;
      padding: 2rem;
    }
    .contact-box .contact-intro {
      font-size: 1rem;
      color: var(--ink);
      line-height: 1.7;
      margin-bottom: 1.5rem;
    }
    .contact-box .contact-intro strong { color: var(--charcoal); font-weight: 500; }
    .contact-form { display: flex; flex-direction: column; gap: 1rem; }
    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
    .form-group { display: flex; flex-direction: column; gap: 0.35rem; }
    .form-group label {
      font-size: 0.8rem;
      font-weight: 500;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: var(--slate);
    }
    .form-group input,
    .form-group textarea,
    .form-group select {
      font-family: var(--font-body);
      font-size: 0.95rem;
      font-weight: 300;
      color: var(--ink);
      background: var(--white);
      border: 1px solid #d8d8d0;
      border-radius: 4px;
      padding: 0.6rem 0.85rem;
      transition: border-color 0.2s, box-shadow 0.2s;
      outline: none;
      width: 100%;
    }
    .form-group input:focus,
    .form-group textarea:focus,
    .form-group select:focus {
      border-color: var(--orange);
      box-shadow: 0 0 0 3px rgba(249,115,22,0.12);
    }
    .form-group textarea { resize: vertical; min-height: 110px; }
    .btn-primary {
      display: inline-block;
      background: var(--orange);
      color: var(--white);
      font-family: var(--font-body);
      font-weight: 500;
      font-size: 0.95rem;
      padding: 0.7rem 1.75rem;
      border-radius: 2px;
      border: none;
      cursor: pointer;
      transition: background 0.2s, transform 0.15s;
      align-self: flex-start;
    }
    .btn-primary:hover    { background: #e56500; transform: translateY(-1px); }
    .btn-primary:disabled { background: #aaa; cursor: not-allowed; transform: none; }
    .form-status {
      font-size: 0.9rem;
      padding: 0.6rem 0.85rem;
      border-radius: 4px;
      display: none;
    }
    .form-status.success { display: block; background: #d1fae5; color: #065f46; border: 1px solid #6ee7b7; }
    .form-status.error   { display: block; background: #fee2e2; color: #991b1b; border: 1px solid #fca5a5; }

    /* ── PLATFORMS ───────────────────────────────────── */
    .platforms {
      background: var(--cloud);
      text-align: center;
    }
    .platform-logos {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      align-items: center;
      gap: 1rem 2.5rem;
      margin-top: 2rem;
    }
    .platform-logo {
      display: flex;
      align-items: center;
      background: var(--white);
      border: 1px solid #e4e4dc;
      border-radius: 8px;
      padding: 1rem 1.5rem;
      transition: box-shadow 0.2s, transform 0.15s;
      min-width: 110px;
      justify-content: center;
    }
    .platform-logo:hover { box-shadow: 0 4px 16px rgba(0,0,0,0.09); transform: translateY(-2px); }
    .platform-logo img { height: 36px; width: auto; object-fit: contain; }
    .platform-logo.wide img { height: 28px; width: 180px; }

    /* ── FOOTER ──────────────────────────────────────── */
    footer {
      background: var(--charcoal);
      color: rgba(255,255,255,0.5);
      text-align: center;
      padding: 2rem 5vw;
      font-size: 0.85rem;
    }
    footer a { color: var(--orange); }

    /* ── Responsive ──────────────────────────────────── */
    @media (max-width: 768px) {
      .hero-grid, .about-inner {
        grid-template-columns: 1fr;
        gap: 2rem;
      }
      .services-grid { grid-template-columns: 1fr; }
      .hero { padding: 2.5rem 1.25rem 2rem; }
      section { padding: 3.5rem 1.25rem; }
      nav { padding: 0 1.25rem; }
      .chart-stack { height: 260px; }
      .chart-item { width: 80%; }
      .chart-item:nth-child(2) { top: 48px; left: 8%; }
      .chart-item:nth-child(3) { top: 96px; left: 16%; }
    }
  </style>
</head>
<body>

  <!-- ── Navigation ── -->
  <nav>
    <div class="nav-logo">
      <span class="fire">fire</span> <span class="spark">spark</span> <span class="rest">analytics</span>
    </div>
    <a href="#contact" class="nav-contact">Contact</a>
  </nav>

  <!-- ── Hero ── -->
  <section class="hero" aria-label="Hero">

    <!-- Centered headline -->
    <div class="hero-headline-wrap">
      <h1 class="hero-headline">
        High-impact, customized analytics
        <em>for busy e-preneurs.</em>
      </h1>
    </div>

    <!-- Two columns -->
    <div class="hero-grid">

      <!-- Left: intro blurb -->
      <div class="hero-left">
        <p>You've already got a full plate as an on-line entrepreneur. Delegate the analytics to me and refocus on what you enjoy. I'll equip you with high-value insights you can use to make data-driven decisions about your content, strategies, and campaigns.</p>
        <div class="hero-decor" aria-hidden="true">• • •</div>
        <p>Whether you're interested in user engagement, conversion rates, or advanced analyses such as customer segmentation and clustering, I've got you covered.</p>
        <div class="hero-decor hero-decor-wave" aria-hidden="true">～</div>
      </div>

      <!-- Right: diagonal charts with donut vertically centered beside them -->
      <div class="hero-right">
        <div class="chart-stack">
          <div class="chart-item">
            <img src="/example-2.png" alt="Active, scrolled and engaged pages" />
          </div>
          <div class="chart-item">
            <img src="/example-1.png" alt="New users over time by first user source" />
          </div>
          <div class="chart-item">
            <img src="/example-3.png" alt="Users by session source % change from prior period" />
          </div>
        </div>
        <div class="hero-donut">
          <img src="/Decor_donut.png" alt="" />
        </div>
      </div>

    </div>

    <!-- Centered CTA -->
    <div class="hero-cta-wrap">
      <a href="#contact" class="hero-cta">Get in touch</a>
    </div>

  </section>

  <!-- ── Why ── -->
  <section class="why" id="why" aria-labelledby="why-heading">
    <div class="why-inner">
      <h2 class="section-title" id="why-heading">Why get customized analytics for your e-business?</h2>
      <div class="why-body">
        <p>One-size-fits-all dashboards on your web host or e-commerce platform offer limited information and aren't focused on what's important to you.</p>
        <p>I can fully leverage your data to provide rich, multi-dimensional insights that speak to your unique business and growth objectives. I excel in identifying signals in the noise, applying context, communicating meaning, and addressing your specific questions and needs.</p>
      </div>
      <div class="why-highlight">
        <p><strong>Importantly, you'll get clarity on where to focus your attention and resources, helping you economize.</strong></p>
        <p>Are your Google Ad campaigns delivering the expected returns on investment? Is your SEO bringing in the traffic? I'll elucidate what's performing and what's not so you can re-calibrate for growth, conversions, and other KPIs.</p>
      </div>
    </div>
  </section>

  <!-- ── Services ── -->
  <section class="services" id="services" aria-labelledby="services-heading">
    <span class="section-label">What I cover</span>
    <h2 class="section-title" id="services-heading">Analytics for every stage of your business</h2>
    <div class="services-grid">
      <div class="service-card">
        <div class="icon">📊</div>
        <h4>User Engagement</h4>
        <p>Understand how visitors interact with your content and where they drop off.</p>
      </div>
      <div class="service-card">
        <div class="icon">🎯</div>
        <h4>Conversion Rates</h4>
        <p>Track and optimize the paths that turn browsers into buyers.</p>
      </div>
      <div class="service-card">
        <div class="icon">📈</div>
        <h4>Campaign ROI</h4>
        <p>Know exactly which campaigns are earning their keep and which aren't.</p>
      </div>
      <div class="service-card">
        <div class="icon">🔍</div>
        <h4>Segmentation & Clustering</h4>
        <p>Advanced analysis to identify your highest-value customer groups.</p>
      </div>
      <div class="service-card">
        <div class="icon">🏷️</div>
        <h4>UTM & Tag Setup</h4>
        <p>Proper tracking foundations: UTM tags, Google Tag Manager, and more.</p>
      </div>
      <div class="service-card">
        <div class="icon">🔀</div>
        <h4>Funnel & Attribution</h4>
        <p>Attribution model selection and full funnel analysis to see the whole picture.</p>
      </div>
    </div>
  </section>

  <!-- ── About ── -->
  <section class="about" id="about" aria-labelledby="about-heading">
    <div class="about-inner">
      <div>
        <span class="section-label">About me</span>
        <h2 class="section-title" id="about-heading">A scientist's approach to your business data</h2>
        <div class="about-bio">
          <p>A former research scientist, I have extensive experience in advanced data analysis. I also have ample experience explaining complicated information to students and other non-experts. If you're not a numbers or analytics person, I've got you.</p>
        </div>
        <div class="about-skills">
          <span class="skill-tag">Statistical Analysis</span>
          <span class="skill-tag">Clustering</span>
          <span class="skill-tag">Regression</span>
          <span class="skill-tag">Classification</span>
          <span class="skill-tag">Data Visualization</span>
          <span class="skill-tag">SEO Analytics</span>
        </div>
        <p class="about-name">Charles Ashton <span>M.S.</span></p>
      </div>
      <div class="contact-box" id="contact">
        <p class="contact-intro">
          <strong>Ready to get impactful insights that will help you optimize your decision making?</strong>
          Get in touch. You and I will start things off with a free consultation to identify your specific analytics needs.
          I'll then outline an analytics package and determine a timeline and quote.
        </p>
        <form class="contact-form" id="contactForm" novalidate>
          <div class="form-row">
            <div class="form-group">
              <label for="name">Your name</label>
              <input type="text" id="name" name="name" placeholder="Jane Smith" required />
            </div>
            <div class="form-group">
              <label for="email">Email address</label>
              <input type="email" id="email" name="email" placeholder="jane@example.com" required />
            </div>
          </div>
          <div class="form-group">
            <label for="business">Your website / business</label>
            <input type="text" id="business" name="business" placeholder="mystore.com" />
          </div>
          <div class="form-group">
            <label for="interest">Primary interest</label>
            <select id="interest" name="interest">
              <option value="">— Select one —</option>
              <option>User engagement analysis</option>
              <option>Conversion rate optimisation</option>
              <option>Campaign ROI / Google Ads</option>
              <option>SEO analytics</option>
              <option>Customer segmentation</option>
              <option>UTM &amp; Tag Manager setup</option>
              <option>Funnel &amp; attribution analysis</option>
              <option>Not sure yet</option>
            </select>
          </div>
          <div class="form-group">
            <label for="message">Anything else you'd like to share?</label>
            <textarea id="message" name="message" placeholder="Tell me a bit about your business and what questions you're trying to answer…"></textarea>
          </div>
          <div class="form-status" id="formStatus"></div>
          <button type="submit" class="btn-primary" id="submitBtn">Send message →</button>
        </form>
      </div>
    </div>
  </section>

  <!-- ── Platforms ── -->
  <section class="platforms" aria-labelledby="platforms-heading">
    <span class="section-label">Tools & Platforms</span>
    <h2 class="section-title" id="platforms-heading">Some of the platforms and services I work with</h2>
    <div class="platform-logos">
      <div class="platform-logo">
        <img src="/logos/google-analytics.svg" alt="Google Analytics" width="36" height="36" />
      </div>
      <div class="platform-logo wide">
        <img src="/logos/search-console.svg" alt="Google Search Console" width="180" height="28" />
      </div>
      <div class="platform-logo">
        <img src="/logos/google-ads.svg" alt="Google Ads" width="36" height="36" />
      </div>
      <div class="platform-logo">
        <img src="/logos/tag-manager.svg" alt="Google Tag Manager" width="36" height="36" />
      </div>
      <div class="platform-logo">
        <img src="/logos/google-tag.svg" alt="Google Tag" width="24" height="24" />
      </div>
    </div>
  </section>

  <!-- ── Footer ── -->
  <footer>
    <p>© <span id="year"></span> Fire Spark Analytics · <a href="mailto:hello@firesparkanalytics.com">hello@firesparkanalytics.com</a></p>
  </footer>

  <script>
    document.getElementById('year').textContent = new Date().getFullYear();

    const form      = document.getElementById('contactForm');
    const status    = document.getElementById('formStatus');
    const submitBtn = document.getElementById('submitBtn');

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      status.className = 'form-status';
      status.textContent = '';

      const name  = form.name.value.trim();
      const email = form.email.value.trim();
      if (!name || !email) {
        status.className = 'form-status error';
        status.textContent = 'Please fill in your name and email address.';
        return;
      }

      submitBtn.disabled = true;
      submitBtn.textContent = 'Sending…';

      try {
        const res = await fetch('/contact', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            name,
            email,
            business: form.business.value.trim(),
            interest: form.interest.value,
            message:  form.message.value.trim(),
          }),
        });

        if (res.ok) {
          status.className = 'form-status success';
          status.textContent = "Message sent! I'll be in touch within one business day.";
          form.reset();
        } else {
          const data = await res.json().catch(() => ({}));
          const msg = [data.error, data.detail].filter(Boolean).join(' — ') || 'Server error';
          throw new Error(msg);
        }
      } catch (err) {
        status.className = 'form-status error';
        status.textContent = `Something went wrong: ${err.message}. Please try emailing hello@firesparkanalytics.com directly.`;
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = 'Send message →';
      }
    });
  </script>

</body>
</html>
